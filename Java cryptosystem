import java.math.BigInteger;
import java.nio.charset.StandardCharsets;
import java.security.MessageDigest;
import java.security.NoSuchAlgorithmException;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.HexFormat;
import java.util.List;
import java.util.Scanner;

public class CellularAutomatonCipher {
    static int[] seedToInitialState(long seed, int width) throws NoSuchAlgorithmException {

        BigInteger bigSeed = BigInteger.valueOf(seed);
        byte[] seedBytes = bigSeed.equals(BigInteger.ZERO)
                ? new byte[]{0}
                : bigSeed.toByteArray();

        if (seedBytes.length > 1 && seedBytes[0] == 0) {
            seedBytes = Arrays.copyOfRange(seedBytes, 1, seedBytes.length);
        }

        MessageDigest digest = MessageDigest.getInstance("SHA-256");
        byte[] hash = digest.digest(seedBytes);

        int[] bits = new int[width];
        int count = 0;
        outer:
        for (byte b : hash) {
            for (int i = 7; i >= 0; i--) {
                bits[count++] = (b >> i) & 1;
                if (count == width) break outer;
            }
        }
        return bits;
    }
    static List<int[]> patternGenerator(int ruleNumber, int generations, long seed)
            throws NoSuchAlgorithmException {

        String ruleBin = String.format("%8s", Integer.toBinaryString(ruleNumber)).replace(' ', '0');
        int width = 2 * generations + 1;

        int[] current = seedToInitialState(seed, width);

        List<int[]> allLines = new ArrayList<>();
        allLines.add(current.clone());

        for (int gen = 0; gen < generations; gen++) {
            // Pad with a zero on each side
            int[] padded = new int[current.length + 2];
            System.arraycopy(current, 0, padded, 1, current.length);

            int[] newRow = new int[current.length];
            for (int i = 0; i < padded.length - 2; i++) {
                int left   = padded[i];
                int center = padded[i + 1];
                int right  = padded[i + 2];
                int neighborhood = (left << 2) | (center << 1) | right;
                newRow[i] = Character.getNumericValue(ruleBin.charAt(7 - neighborhood));
            }
            current = newRow;
            allLines.add(current.clone());
        }
        return allLines;
    }


    static int[] generateKeystream(int rule, long seed, int lengthNeeded)
            throws NoSuchAlgorithmException {

        List<int[]> grid = patternGenerator(rule, lengthNeeded, seed);
        int center = grid.get(0).length / 2;

        int[] bits = new int[lengthNeeded];
        for (int i = 0; i < lengthNeeded; i++) {
            bits[i] = grid.get(i + 1)[center];   // skip generation 0
        }
        return bits;
    }

    

    static byte[] xorBytes(byte[] message, int[] keystreamBits) {
        byte[] result = new byte[message.length];
        for (int i = 0; i < message.length; i++) {
            int keystreamByte = 0;
            for (int bit = 0; bit < 8; bit++) {
                keystreamByte = (keystreamByte << 1) | keystreamBits[i * 8 + bit];
            }
            result[i] = (byte) ((message[i] & 0xFF) ^ keystreamByte);
        }
        return result;
    }

  

    static byte[] encrypt(String message, int rule, long seed)
            throws NoSuchAlgorithmException {

        byte[] messageBytes = message.getBytes(StandardCharsets.UTF_8);
        int bitsNeeded = messageBytes.length * 8;
        int[] keystream = generateKeystream(rule, seed, bitsNeeded);
        return xorBytes(messageBytes, keystream);
    }

    static String decrypt(byte[] ciphertext, int rule, long seed)
            throws NoSuchAlgorithmException {

        int bitsNeeded = ciphertext.length * 8;
        int[] keystream = generateKeystream(rule, seed, bitsNeeded);
        byte[] plainBytes = xorBytes(ciphertext, keystream);
        try {
            String result = new String(plainBytes, StandardCharsets.UTF_8);
            if (!Arrays.equals(result.getBytes(StandardCharsets.UTF_8), plainBytes)) {
                return null;
            }
            return result;
        } catch (Exception e) {
            return null;
        }
    }


    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        HexFormat hex = HexFormat.of();

        while (true) {
            System.out.print("Do you want to encrypt or decrypt a message? ");
            String choice = scanner.nextLine().trim().toLowerCase();

            if (choice.equals("encrypt")) {
                long seed;
                System.out.print("What seed do you want to encrypt this message with? ");
                try {
                    seed = Long.parseLong(scanner.nextLine().trim());
                } catch (NumberFormatException e) {
                    System.out.println("Please enter an integer.");
                    continue;
                }

                System.out.print("Enter your message: ");
                String message = scanner.nextLine();

                try {
                    byte[] ciphertext = encrypt(message, 30, seed);
                    System.out.println("Cipher text: " + hex.formatHex(ciphertext));
                } catch (NoSuchAlgorithmException e) {
                    System.err.println("SHA-256 not available: " + e.getMessage());
                }

            } else if (choice.equals("decrypt")) {
                long seed;
                System.out.print("What seed decrypts this message? ");
                try {
                    seed = Long.parseLong(scanner.nextLine().trim());
                } catch (NumberFormatException e) {
                    System.out.println("Please enter an integer.");
                    continue;
                }

                System.out.print("Put your ciphertext in here: ");
                String hexInput = scanner.nextLine().trim();
                byte[] ciphertext;
                try {
                    ciphertext = hex.parseHex(hexInput);
                } catch (IllegalArgumentException e) {
                    System.out.println("Invalid hex input.");
                    continue;
                }

                try {
                    String result = decrypt(ciphertext, 30, seed);
                    if (result == null) {
                        System.out.println("Decryption failed — wrong seed or corrupted ciphertext.");
                    } else {
                        System.out.println("Decrypted text: " + result);
                    }
                } catch (NoSuchAlgorithmException e) {
                    System.err.println("SHA-256 not available: " + e.getMessage());
                }

            } else {
                System.out.println("Please type 'encrypt' or 'decrypt'.");
            }
        }
    }
}
